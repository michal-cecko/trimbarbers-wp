{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": ["assets/js/**/*"],
  "exclude": ["node_modules", "assets/js/libs/**/*", "**/*.min.js", "assets/js/components/**/*"],
  "compilerOptions": {
    "preserveConstEnums": true,
    "removeComments": true,
    "noImplicitAny": true,
    "target": "es5",
    "isolatedModules": false
  }
}
